            "csro:description": "Integrity of network isolation controls compromised, enabling unauthorized network access to segmented assets and confidentiality breach across network boundaries",
            "csro:hasImpactRating": {
                "@id": "csro:Critical"
            },
            "csro:indicates": {
                "@id": "csro:NetworkIsolationBreachRisk_AirGappedScenario"
