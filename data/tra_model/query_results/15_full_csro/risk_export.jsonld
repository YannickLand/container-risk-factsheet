        {
            "@id": "csro:ContainerCgroupDoS",
            "@type": "csro:ContainerAttackTechnique",
            "csro:description": "Manipulating cgroup limits to cause denial of service by exhausting host system resources",
            "csro:referencesAttackTechnique": {
                "@id": "d3f:T1499"
            },
            "csro:requiresTrait": {
                "@id": "csro:host_cgroup"
            }
        },
        {
            "@id": "csro:ResourceExhaustionDoS_AirGappedScenario",
            "@type": "csro:Impact",
            "rdfs:label": "ResourceExhaustionDoS (AirGappedScenario)",
            "csro:description": "Complete loss of availability for host system and all hosted applications due to critical resource exhaustion",
            "csro:hasImpactRating": {
                "@id": "csro:Critical"
            },
            "csro:indicates": {
                "@id": "csro:ServiceAvailabilityLossRisk_AirGappedScenario"
            }
