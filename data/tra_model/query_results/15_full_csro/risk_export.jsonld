        {
            "@id": "csro:ContainerSystemAdminEscape",
            "@type": "csro:ContainerAttackTechnique",
            "csro:description": "Leveraging CAP_SYS_ADMIN capability to perform container escape through mounting host filesystems, manipulating namespaces, or exploiting kernel interfaces",
            "csro:referencesAttackTechnique": {
                "@id": "d3f:T1611"
            },
            "csro:requiresTrait": {
                "@id": "csro:cap_add_CAP_SYS_ADMIN"
            }
