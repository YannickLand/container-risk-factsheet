            "rdfs:label": "ContainerEscapeImpact (AirGappedScenario)",
            "csro:description": "Complete loss of confidentiality, integrity, and availability of host system through container escape, enabling full unauthorized control over all system resources and data",
            "csro:hasImpactRating": {
                "@id": "csro:Disastrous"
            },
            "csro:indicates": {
