FROM python:3.12-slim

WORKDIR /app

# Install dependencies first for layer caching
COPY pyproject.toml ./
RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -e "."

# Copy source code
COPY factsheet/ ./factsheet/
COPY api/ ./api/
COPY data/ ./data/

EXPOSE 5004

CMD ["python", "-m", "api.api_server"]
