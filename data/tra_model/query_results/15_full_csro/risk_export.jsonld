        {
            "@id": "csro:ContainerPtraceProcessDiscovery",
            "@type": "csro:ContainerAttackTechnique",
            "csro:description": "Leveraging CAP_SYS_PTRACE and host PID namespace to discover and enumerate host processes for information gathering",
            "csro:referencesAttackTechnique": {
                "@id": "d3f:T1057"
            },
            "csro:requiresTrait": [
                {
                    "@id": "csro:cap_add_CAP_SYS_PTRACE"
                },
                {
                    "@id": "csro:host_pid"
                }
            ]
        },
        {
            "@id": "csro:HostProcessInformationDisclosure_AirGappedScenario",
            "@type": "csro:Impact",
            "rdfs:label": "HostProcessInformationDisclosure (AirGappedScenario)",
            "csro:description": "Confidentiality of host process information compromised, exposing system architecture, running services, and potential security weaknesses",
            "csro:hasImpactRating": {
                "@id": "csro:Moderate"
            },
            "csro:indicates": {
                "@id": "csro:SystemInformationExposureRisk_AirGappedScenario"
            }
        },
        {
            "@id": "d3f:T1057",
            "@type": "d3f:ATTACKEnterpriseTechnique",
            "rdfs:label": "Process Discovery",
            "d3f:attack-id": "T1057",
            "d3f:definition": "Adversaries may attempt to get information about running processes on a system. Information obtained could be used to gain an understanding of common software/applications running on systems within the network. Administrator or otherwise elevated access may provide better process details. Adversaries may use the information from [Process Discovery](https://attack.mitre.org/techniques/T1057) during automated discovery to shape follow-on behaviors, including whether or not the adversary fully infects the target and/or attempts specific actions."
        },
