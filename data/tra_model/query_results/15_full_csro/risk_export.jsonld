        {
            "@id": "csro:ContainerCgroupResourceHijacking",
            "@type": "csro:ContainerAttackTechnique",
            "csro:description": "Manipulating cgroup resource allocations to hijack compute resources for cryptomining or other unauthorized resource consumption",
