        {
            "@id": "csro:ContainerPtraceInjection",
            "@type": "csro:ContainerAttackTechnique",
            "csro:description": "Using ptrace system calls for process injection to achieve container escape in environments with CAP_SYS_PTRACE capability and host PID namespace access",
            "csro:referencesAttackTechnique": {
                "@id": "d3f:T1055.008"
            },
            "csro:requiresTrait": [
                {
                    "@id": "csro:cap_add_CAP_SYS_PTRACE"
                },
                {
                    "@id": "csro:host_pid"
                }
            ]
        },
