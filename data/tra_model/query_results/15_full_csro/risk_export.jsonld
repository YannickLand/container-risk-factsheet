        {
            "@id": "csro:ContainerKernelModuleLoading",
            "@type": "csro:ContainerAttackTechnique",
            "csro:description": "Loading malicious kernel modules from containers with CAP_SYS_MODULE capability to achieve persistence and host-level compromise",
            "csro:referencesAttackTechnique": {
                "@id": "d3f:T1547.006"
            },
            "csro:requiresTrait": {
                "@id": "csro:cap_add_CAP_SYS_MODULE"
            }
        },
        {
            "@id": "csro:KernelIntegrityCompromise_AirGappedScenario",
            "@type": "csro:Impact",
            "rdfs:label": "KernelIntegrityCompromise (AirGappedScenario)",
            "csro:description": "Complete loss of system integrity and confidentiality at kernel level, enabling persistent unauthorized control over all system operations and data",
            "csro:hasImpactRating": {
                "@id": "csro:Disastrous"
            },
            "csro:indicates": {
                "@id": "csro:SystemIntegrityLossRisk_AirGappedScenario"
            }
        },
        {
            "@id": "d3f:T1547.006",
            "@type": "d3f:ATTACKEnterpriseTechnique",
            "rdfs:label": "Kernel Modules and Extensions",
            "d3f:attack-id": "T1547.006",
            "d3f:definition": "Adversaries may modify the kernel to automatically execute programs on system boot. Loadable Kernel Modules (LKMs) are pieces of code that can be loaded and unloaded into the kernel upon demand. They extend the functionality of the kernel without the need to reboot the system. For example, one type of module is the device driver, which allows the kernel to access hardware connected to the system.(Citation: Linux Kernel Programming) "
        },
        {
            "@id": "csro:cap_add_CAP_SYS_MODULE",
            "@type": "csro:ContainerDeploymentTrait",
            "csro:description": "Adding CAP_SYS_MODULE capability to load and unload kernel modules"
        },
